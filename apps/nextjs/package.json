{
  "name": "@capibara/nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .open-next .turbo node_modules",
    "dev": "pnpm with-env next dev --turbopack",
    "preview": "pnpm with-env opennextjs-cloudflare build && pnpm with-env opennextjs-cloudflare preview",
    "cf:build": "pnpm with-env opennextjs-cloudflare build",
    "cf:deploy": "pnpm with-env opennextjs-cloudflare deploy",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@capibara/api": "workspace:*",
    "@capibara/auth": "workspace:*",
    "@capibara/db": "workspace:*",
    "@capibara/ui": "workspace:*",
    "@capibara/validators": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.6",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "next": "^15.3.3",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@capibara/eslint-config": "workspace:*",
    "@capibara/prettier-config": "workspace:*",
    "@capibara/tailwind-config": "workspace:*",
    "@capibara/tsconfig": "workspace:*",
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/node": "^22.15.29",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "jiti": "^2.4.2",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "wrangler": "^4.21.2"
  },
  "prettier": "@capibara/prettier-config"
}
